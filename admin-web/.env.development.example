# Copy to `.env.development` (same folder as vite.config.js). Restart `npm run dev` after edits.

# API base URL (no trailing path). Used for:
# - Vite `/api` proxy target in dev
# - Browser fetch() in src/api.js (so Network tab shows this host, not localhost)
# Use https:// if your host redirects HTTP → HTTPS (avoid POST issues).
VITE_API_PROXY_TARGET=http://localhost:5119

# Optional override for production builds (`vite build`). If unset at build time, uses
# VITE_API_PROXY_TARGET when embedded, or leave both unset for same-origin `/api`.
# VITE_API_BASE_URL=https://your-api-host
